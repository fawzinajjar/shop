# ---- Database (Neon serverless Postgres, or any Postgres) ----
# Neon: copy the pooled connection string from the dashboard.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ---- Site ----
# Public origin, used to build Stripe success/cancel URLs.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---- Auth (Auth.js / NextAuth) ----
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# ---- Cloudflare R2 (object storage for product PNGs) ----
# Leave R2_* unset for local dev: the seed writes placeholder PNGs to public/img
# and the store serves them locally. Set these to use R2 in production.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="products"
# Public bucket URL (R2 r2.dev domain or your CDN domain), no trailing slash.
R2_PUBLIC_URL=""

# ---- Stripe (checkout + order webhook) ----
STRIPE_SECRET_KEY="sk_test_..."
# From `stripe listen` locally, or the dashboard webhook signing secret in prod.
STRIPE_WEBHOOK_SECRET="whsec_..."

# ---- Seed tuning (optional) ----
# SEED_COUNT=100000
# SEED_IMAGE_POOL=300
