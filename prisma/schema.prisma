generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  BUYER
  SELLER
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  role         Role           @default(BUYER)
  createdAt    DateTime       @default(now())
  seller       SellerProfile?
  products     Product[]
  orders       Order[]
}

model SellerProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeName String
  bio       String   @default("")
  avatarKey String? // R2 key for avatar image
  createdAt DateTime @default(now())
}

model Product {
  id          String         @id @default(cuid())
  seq         Int            @unique @default(autoincrement())
  slug        String         @unique
  title       String
  description String
  priceCents  Int
  currency    String         @default("usd")
  category    String
  attributes  Json           @default("{}")
  createdAt   DateTime       @default(now())
  sellerId    String?
  seller      User?          @relation(fields: [sellerId], references: [id], onDelete: SetNull)
  images      ProductImage[]
  orderItems  OrderItem[]

  // Keyset pagination orders by seq; these speed up catalog filters.
  @@index([category, seq])
  @@index([priceCents])
  @@index([sellerId, seq])
  // A pg_trgm GIN index on title/description is added in prisma/search-index.sql
  // for fast case-insensitive `contains` search at 100k rows.
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  r2Key     String // object key in the R2 bucket
  alt       String  @default("")
  position  Int     @default(0)

  @@index([productId])
}

model Order {
  id              String      @id @default(cuid())
  email           String
  userId          String?
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  status          String      @default("pending") // pending | paid | failed
  totalCents      Int
  currency        String      @default("usd")
  stripeSessionId String      @unique
  createdAt       DateTime    @default(now())
  items           OrderItem[]

  @@index([email])
  @@index([userId])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId  String
  product    Product @relation(fields: [productId], references: [id])
  title      String // snapshot at purchase time
  priceCents Int
  quantity   Int

  @@index([orderId])
}
